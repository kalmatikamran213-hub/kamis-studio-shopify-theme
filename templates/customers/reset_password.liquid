<div class="page-wrap narrow">
  <span class="page-eyebrow">account</span>
  <h1 class="page-title">reset password</h1>
  <p class="page-intro">enter a new password for {{ email }}.</p>

  {%- form 'reset_customer_password', class: 'form-grid' -%}
    {%- if form.errors -%}
      <p class="form-message full">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div class="form-field full">
      <label class="form-label" for="reset-password">new password</label>
      <input class="form-input" type="password" name="customer[password]" id="reset-password" autocomplete="new-password" required>
    </div>
    <div class="form-field full">
      <label class="form-label" for="reset-password-confirm">confirm password</label>
      <input class="form-input" type="password" name="customer[password_confirmation]" id="reset-password-confirm" autocomplete="new-password" required>
    </div>
    <div class="full"><button class="btn-fill" type="submit">reset password</button></div>
  {%- endform -%}
</div>
