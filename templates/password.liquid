<div class="ph-video" style="height:100vh">
  <div class="ph-video-bg kb" style="background: linear-gradient(135deg, #A89177, #7A6852, #3F3429, #1F1A14);"></div>
  <div class="ph-video-stripes"></div>
  <div class="ph-video-grain"></div>
  <div class="ph-video-vignette"></div>

  <div style="position:absolute; inset:0; z-index:3; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:28px; color:#fff; text-align:center; padding: 0 20px;">
    <div style="font-weight:600; letter-spacing:-0.02em; font-size:20px;">kamis<span style="color:#C96F6F">:</span>studio</div>
    <h1 style="font-size:clamp(40px, 8vw, 88px); font-weight:600; letter-spacing:-0.04em; margin:0; line-height:1;">coming soon</h1>
    <p style="color:rgba(255,255,255,0.7); max-width:420px; font-size:14px; margin:0;">drop:one of spring:summer '26. leave your email with the shop owner, or enter the password to preview.</p>

    {%- form 'storefront_password', style: 'display:flex; flex-wrap:wrap; gap:8px; width:min(360px, 90vw);' -%}
      <input type="password" name="password" placeholder="store password"
             style="flex:1; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.35); color:#fff; padding:12px 14px; font:inherit; font-size:13px;">
      <button class="btn-outline white" type="submit">enter</button>
      {%- if form.errors -%}<p style="color:#FFB4A8; font-size:13px; margin:0; width:100%;">wrong password — try again.</p>{%- endif -%}
    {%- endform -%}
  </div>
</div>
