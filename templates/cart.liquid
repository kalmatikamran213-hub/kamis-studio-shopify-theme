{%- comment -%}
  Standard cart page. Most users use the drawer; this is the fallback at /cart.
{%- endcomment -%}
<div class="shop-root" style="padding-top: calc(32px + 56px + 24px); padding-left: var(--pad-x); padding-right: var(--pad-x); padding-bottom: 64px; max-width: 880px; margin: 0 auto;">
  <h1 style="font-size: clamp(22px, 2.4vw, 34px); font-weight: 500; letter-spacing: -0.025em; margin: 0 0 32px;">bag</h1>

  {%- if cart.item_count == 0 -%}
    <div class="empty">
      <p>your bag is empty.</p>
      <p class="muted">drop:one of spring:summer '26 is now live.</p>
      <a class="btn-outline dark" style="text-decoration:none; margin-top: 18px" href="/collections/all">see:more</a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <ul class="bag-list" style="border-top: 1px solid var(--rule);">
        {%- for item in cart.items -%}
          <li class="bag-item" style="padding: 16px 0; border-bottom: 1px solid var(--rule);" data-line="{{ forloop.index }}">
            <a href="{{ item.url }}">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}">
              {%- else -%}
                {% render 'striped-placeholder', label: item.product.title, sub: 'image', class: '' %}
              {%- endif -%}
            </a>
            <div class="bag-meta">
              <a href="{{ item.url }}" style="color:inherit; text-decoration:none"><div class="bag-name">{{ item.product.title | downcase }}</div></a>
              <div class="bag-variant">{{ item.variant.title | downcase }}</div>
              <div class="bag-price">{{ item.final_line_price | money }}</div>
              <div class="qty" style="margin-top:8px">
                <button type="button" data-qty="dec" aria-label="decrease">−</button>
                <input name="updates[]" value="{{ item.quantity }}" type="number" min="0">
                <button type="button" data-qty="inc" aria-label="increase">+</button>
              </div>
            </div>
            <button type="button" class="linklike small" data-remove>{{ 'cart.general.remove' | t }}</button>
          </li>
        {%- endfor -%}
      </ul>
      <div class="bag-foot" style="margin-top: 24px">
        <div class="bag-sub" style="font-size: 16px"><span>{{ 'cart.general.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></div>
        <div style="display:flex; gap:12px; margin-top: 12px;">
          <button class="btn-outline dark" type="submit" name="update" style="flex:1">update bag</button>
          <button class="btn-fill" type="submit" name="checkout" style="flex:2">{{ 'cart.general.checkout' | t }}</button>
        </div>
        <p class="muted small">{{ 'cart.general.shipping_note' | t }}</p>
      </div>
    </form>

    <script>
      // page-local qty / remove — posts through the cart form
      // (capture phase so the drawer's Ajax handlers don't double-fire)
      (function () {
        var form = document.querySelector('.template-cart form[action*="cart"], form[action="{{ routes.cart_url }}"]');
        if (!form) return;
        form.addEventListener('click', function (e) {
          var dec = e.target.closest('[data-qty="dec"]');
          var inc = e.target.closest('[data-qty="inc"]');
          var rm = e.target.closest('[data-remove]');
          if (!dec && !inc && !rm) return;
          e.preventDefault(); e.stopPropagation();
          var item = e.target.closest('.bag-item');
          var input = item && item.querySelector('input[name="updates[]"]');
          if (!input) return;
          var q = parseInt(input.value, 10) || 0;
          if (dec) input.value = Math.max(0, q - 1);
          if (inc) input.value = q + 1;
          if (rm) input.value = 0;
          form.submit();
        }, true);
      })();
    </script>
  {%- endif -%}
</div>
