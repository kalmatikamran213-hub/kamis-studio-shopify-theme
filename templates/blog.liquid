<div class="shop-root">
  <header class="shop-head">
    <span class="shop-eyebrow"><span class="sfx-pulse-dot"></span> journal</span>
    <h1 class="shop-title">{{ blog.title | downcase }}</h1>
  </header>

  <section style="padding: 0 var(--pad-x) 80px;">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
      {%- paginate blog.articles by 10 -%}
        {%- for article in blog.articles -%}
          <article style="background: var(--bg); padding: 24px;">
            {%- if article.image -%}
              <a href="{{ article.url }}"><img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title | escape }}" style="width:100%; aspect-ratio: 4/3; object-fit: cover; background: var(--card);"></a>
            {%- endif -%}
            <div class="muted small" style="margin-top: 16px">{{ article.published_at | date: "%b %d, %Y" }}</div>
            <h2 style="margin: 4px 0 8px; font-size: 18px; font-weight: 500; letter-spacing: -0.01em;"><a href="{{ article.url }}" style="color:inherit; text-decoration:none">{{ article.title | downcase }}</a></h2>
            <p class="muted" style="font-size: 13px; margin: 0;">{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>
          </article>
        {%- endfor -%}
      {%- endpaginate -%}
    </div>
  </section>
</div>
