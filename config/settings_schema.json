[
  {
    "name": "theme_info",
    "theme_name": "Kamis Studio",
    "theme_version": "2.0.0",
    "theme_author": "Kamis Studio",
    "theme_documentation_url": "https://kamis.studio",
    "theme_support_url": "mailto:studio@kamis.studio"
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "header", "content": "Brand palette" },
      { "type": "color", "id": "bg_color",     "label": "Background",        "default": "#FFFFFF" },
      { "type": "color", "id": "fg_color",     "label": "Foreground (text)", "default": "#0A0A0A" },
      { "type": "color", "id": "muted_color",  "label": "Muted text",        "default": "#8A8A8A" },
      { "type": "color", "id": "rule_color",   "label": "Rules / borders",   "default": "#E6E6E6" },
      { "type": "color", "id": "card_color",   "label": "Card surface",      "default": "#F5F5F5" },
      { "type": "color", "id": "accent_color", "label": "Accent (burgundy)", "default": "#7A1F22",
        "info": "Wordmark colon, accent CTAs, ship-progress bar, scroll progress." },
      { "type": "color", "id": "announcement_bg", "label": "Announcement bar background", "default": "#0A0A0A" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "range", "id": "wordmark_weight", "label": "Wordmark weight", "min": 400, "max": 800, "step": 100, "default": 600 }
    ]
  },
  {
    "name": "Layout & motion",
    "settings": [
      { "type": "range",    "id": "corner_radius",      "label": "Corner radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 0 },
      { "type": "checkbox", "id": "animations_enabled", "label": "Enable scroll animations", "default": true }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      { "type": "image_picker", "id": "favicon",       "label": "Favicon" },
      { "type": "text",         "id": "tagline",       "label": "Tagline",      "default": "drop:one of spring:summer '26" },
      { "type": "text",         "id": "season_note",   "label": "Season note",  "default": "spring:summer '26" },
      { "type": "text",         "id": "contact_email", "label": "Contact email", "default": "studio@kamis.studio" },
      { "type": "text",         "id": "social_line",   "label": "Social line (menu footer)", "default": "instagram · tiktok · pinterest" },
      { "type": "text",         "id": "cities_line",   "label": "Cities line",  "default": "lahore · paris · new york" }
    ]
  },
  {
    "name": "Navigation",
    "settings": [
      { "type": "link_list", "id": "overlay_menu", "label": "Fullscreen menu links", "default": "main-menu",
        "info": "Big numbered links in the fullscreen menu overlay." }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "url", "id": "social_tiktok",    "label": "TikTok URL" },
      { "type": "url", "id": "social_pinterest", "label": "Pinterest URL" }
    ]
  },
  {
    "name": "Search & cart",
    "settings": [
      { "type": "text",     "id": "popular_searches",        "label": "Popular searches",
        "info": "Comma-separated chips shown in the search overlay.",
        "default": "varsity jacket, hoodie, wide leg trouser, monogram cap, denim" },
      { "type": "number",   "id": "free_shipping_threshold", "label": "Free shipping threshold",
        "info": "In your store currency (e.g. 25000). Drives the bag progress bar.", "default": 25000 },
      { "type": "checkbox", "id": "show_bag_fab",            "label": "Show floating bag button", "default": true }
    ]
  }
]
