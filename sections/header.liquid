<nav class="nav{% if section.settings.always_solid %} is-scrolled always-solid{% endif %}" data-header>
  <div class="nav-inner">
    <ul class="nav-l">
      <li>
        <button class="linklike menu-btn" type="button" data-open="menu" aria-label="menu">
          <span class="menu-lines" aria-hidden="true"><i></i><i></i></span>
          menu
        </button>
      </li>
      {%- if section.settings.menu != blank -%}
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}"{% if link.active %} class="nav-active"{% endif %}>
              {%- if link.title contains 'drop' -%}<span data-accent>{{ link.title | downcase }}</span>{%- else -%}{{ link.title | downcase }}{%- endif -%}
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        <li><a href="{{ routes.all_products_collection_url }}">shop</a></li>
        <li><a href="/pages/lookbook">lookbook</a></li>
        <li><a href="{{ routes.all_products_collection_url }}"><span data-accent>drop:one</span></a></li>
      {%- endif -%}
    </ul>

    <a href="{{ shop.url }}" class="wordmark" aria-label="{{ shop.name }}">
      {%- assign mark = section.settings.wordmark | default: 'kamis:studio' -%}
      {%- if mark contains ':' -%}
        {%- assign parts = mark | split: ':' -%}
        <span>{{ parts[0] }}</span><span class="wm-colon">:</span><span>{{ parts[1] }}</span>
      {%- else -%}
        <span>{{ mark }}</span>
      {%- endif -%}
    </a>

    <ul class="nav-r">
      <li><a href="{{ section.settings.info_link | default: '/pages/contact' }}">info</a></li>
      <li><a href="{{ routes.account_url | default: '/account' }}">account</a></li>
      <li><button class="linklike" type="button" data-open="search">search</button></li>
      <li>
        <button class="linklike" type="button" data-open="bag">
          bag <span class="bag-count" data-bag-count>({{ cart.item_count }})</span>
        </button>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav.is-scrolled [data-accent] { color: var(--accent); }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text",      "id": "wordmark",     "label": "Wordmark", "default": "kamis:studio",
      "info": "Use a colon to colour the separator with the brand accent." },
    { "type": "link_list", "id": "menu",         "label": "Left menu", "default": "main-menu",
      "info": "Links shown left of the wordmark. Leave default for shop / lookbook / drop:one." },
    { "type": "url",       "id": "info_link",    "label": "Info link", "info": "Defaults to /pages/contact" },
    { "type": "checkbox",  "id": "always_solid", "label": "Always solid background",
      "info": "When off, the nav is transparent over the hero and turns solid on scroll.", "default": false }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
