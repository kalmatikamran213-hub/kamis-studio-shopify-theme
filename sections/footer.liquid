<footer class="foot">
  <div class="foot-inner">
    <div class="foot-brand">
      <div class="foot-mark">{{ section.settings.wordmark | default: 'kamis:studio' }}</div>
      {%- if section.settings.tagline != blank -%}
        <p class="muted">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>
    <div class="foot-cols">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div {{ block.shopify_attributes }}>
              <h5>{{ block.settings.heading | downcase }}</h5>
              <ul>
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" style="color:inherit;text-decoration:none">{{ link.title | downcase }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'newsletter' -%}
            <div {{ block.shopify_attributes }}>
              <h5>{{ block.settings.heading | default: 'connect' | downcase }}</h5>
              {%- form 'customer', class: 'news' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="{{ 'newsletter.placeholder' | t }}" required>
                <button type="submit" aria-label="{{ 'newsletter.submit' | t }}">→</button>
              {%- endform -%}
              {%- if block.settings.show_socials -%}
                <ul class="socials">
                  {%- if settings.social_instagram != blank -%}<li><a href="{{ settings.social_instagram }}" style="color:inherit;text-decoration:none">instagram</a></li>{%- endif -%}
                  {%- if settings.social_tiktok != blank -%}<li><a href="{{ settings.social_tiktok }}" style="color:inherit;text-decoration:none">tiktok</a></li>{%- endif -%}
                  {%- if settings.social_pinterest != blank -%}<li><a href="{{ settings.social_pinterest }}" style="color:inherit;text-decoration:none">pinterest</a></li>{%- endif -%}
                </ul>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="foot-bottom">
    <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
    <span>{{ cart.currency.iso_code | downcase }}</span>
    <span>privacy · terms · cookies</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "wordmark", "label": "Wordmark", "default": "kamis:studio" },
    { "type": "text", "id": "tagline",  "label": "Tagline",  "default": "premium ai-crafted visuals for fashion & product brands. lahore · paris · new york." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text",      "id": "heading", "label": "Heading", "default": "shop" },
        { "type": "link_list", "id": "menu",    "label": "Menu" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter column",
      "settings": [
        { "type": "text",     "id": "heading",      "label": "Heading", "default": "connect" },
        { "type": "checkbox", "id": "show_socials", "label": "Show social links",  "default": true }
      ]
    }
  ],
  "presets": [{
    "name": "Footer",
    "blocks": [
      { "type": "menu", "settings": { "heading": "shop" } },
      { "type": "menu", "settings": { "heading": "info" } },
      { "type": "menu", "settings": { "heading": "support" } },
      { "type": "newsletter" }
    ]
  }]
}
{% endschema %}
