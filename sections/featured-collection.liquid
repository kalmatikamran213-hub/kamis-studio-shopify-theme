{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.limit | default: 4
-%}
<section class="section" id="section-{{ section.id }}">
  <div class="pg-wrap">
    {%- if section.settings.label != blank or section.settings.sub != blank or section.settings.cta != blank -%}
      <div class="sec-head">
        <span class="sec-label">{{ section.settings.label }}</span>
        {%- if section.settings.sub != blank -%}<span class="sec-sub muted">{{ section.settings.sub }}</span>{%- endif -%}
        {%- if section.settings.cta != blank -%}
          <a class="btn-outline dark" style="text-decoration:none" href="{{ section.settings.cta_link | default: collection.url | default: routes.all_products_collection_url }}">{{ section.settings.cta }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="pg-grid">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: limit -%}
          <div class="pg-item" style="--i: {{ forloop.index0 }}">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign tints = section.settings.placeholder_palette | default: '#EFEDE8,#EAE6DC,#E6E8EB,#F2EFE8' | split: ',' -%}
        {%- for i in (1..limit) -%}
          <div class="pg-item" style="--i: {{ forloop.index0 }}">
            {% render 'product-card',
              placeholder_label: section.settings.label | default: 'product · placeholder',
              placeholder_bg: tints[forloop.index0 | modulo: tints.size],
              placeholder_fg: '#D5D0C5' %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "header", "content": "Source" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Number of products", "min": 4, "max": 12, "step": 4, "default": 4 },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "label", "label": "Label (left)" },
    { "type": "text", "id": "sub",   "label": "Sub (muted)" },
    { "type": "text", "id": "cta",   "label": "Button text" },
    { "type": "url",  "id": "cta_link", "label": "Button link" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "placeholder_palette", "label": "Placeholder palette",
      "info": "Comma-separated hex used for striped fallbacks when no collection is set.",
      "default": "#EFEDE8,#EAE6DC,#E6E8EB,#F2EFE8" }
  ],
  "presets": [{ "name": "Product grid" }]
}
{% endschema %}
