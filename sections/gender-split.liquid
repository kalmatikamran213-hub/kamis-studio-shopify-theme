<section class="gender-split" id="section-{{ section.id }}">
  <div class="gender-split-inner">

    <div class="gender-pane" data-reveal>
      {%- if section.settings.men_video != blank -%}
        <div class="gender-media">
          {{ section.settings.men_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, style: "width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0" }}
        </div>
      {%- elsif section.settings.men_image != blank -%}
        <div class="gender-media">
          <img src="{{ section.settings.men_image | image_url: width: 1200 }}"
               alt="{{ section.settings.men_label | default: 'men' | escape }}"
               style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0" loading="lazy">
        </div>
      {%- else -%}
        <div class="gender-media">
          {% render 'striped-placeholder', label: 'men · collection', sub: 'upload image or video', bg: '#1A1A1A', fg: '#333' %}
        </div>
      {%- endif -%}
      <div class="gender-vignette"></div>
      <div class="gender-label">
        <span class="gender-eyebrow">{{ section.settings.men_eyebrow | default: 'for him' }}</span>
        <h2 class="gender-title">{{ section.settings.men_label | default: 'men' }}</h2>
        <a href="{{ section.settings.men_link | default: '/collections/all?filter.p.tag=men' }}" class="btn-outline white" style="text-decoration:none">{{ section.settings.men_button | default: 'shop men' }}</a>
      </div>
    </div>

    <div class="gender-pane" data-reveal>
      {%- if section.settings.women_video != blank -%}
        <div class="gender-media">
          {{ section.settings.women_video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, style: "width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0" }}
        </div>
      {%- elsif section.settings.women_image != blank -%}
        <div class="gender-media">
          <img src="{{ section.settings.women_image | image_url: width: 1200 }}"
               alt="{{ section.settings.women_label | default: 'women' | escape }}"
               style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0" loading="lazy">
        </div>
      {%- else -%}
        <div class="gender-media">
          {% render 'striped-placeholder', label: 'women · collection', sub: 'upload image or video', bg: '#EDEAE4', fg: '#C8C2B5' %}
        </div>
      {%- endif -%}
      <div class="gender-vignette"></div>
      <div class="gender-label">
        <span class="gender-eyebrow">{{ section.settings.women_eyebrow | default: 'for her' }}</span>
        <h2 class="gender-title">{{ section.settings.women_label | default: 'women' }}</h2>
        <a href="{{ section.settings.women_link | default: '/collections/all?filter.p.tag=women' }}" class="btn-outline white" style="text-decoration:none">{{ section.settings.women_button | default: 'shop women' }}</a>
      </div>
    </div>

  </div>
</section>

<style>
  .gender-split { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .gender-split-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); }
  .gender-pane { position: relative; aspect-ratio: 3/4; overflow: hidden; background: var(--card); }
  .gender-media { position: absolute; inset: 0; }
  .gender-vignette { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 50%, transparent 100%); z-index: 2; }
  .gender-label { position: absolute; bottom: 40px; left: 40px; z-index: 3; color: #fff; }
  .gender-eyebrow { display: block; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; margin-bottom: 8px; }
  .gender-title { font-size: clamp(36px, 5vw, 72px); font-weight: 600; letter-spacing: -0.03em; margin: 0 0 24px; line-height: 1; }
  @media (max-width: 640px) {
    .gender-split-inner { grid-template-columns: 1fr; }
    .gender-pane { aspect-ratio: 4/5; }
    .gender-label { bottom: 24px; left: 24px; }
  }
</style>

{% schema %}
{
  "name": "Men / Women split",
  "settings": [
    { "type": "header", "content": "Men's side" },
    { "type": "video",        "id": "men_video",   "label": "Men — Video (takes priority)" },
    { "type": "image_picker", "id": "men_image",   "label": "Men — Image (fallback)" },
    { "type": "text",         "id": "men_eyebrow", "label": "Eyebrow",     "default": "for him" },
    { "type": "text",         "id": "men_label",   "label": "Title",       "default": "men" },
    { "type": "text",         "id": "men_button",  "label": "Button text", "default": "shop men" },
    { "type": "url",          "id": "men_link",    "label": "Button link", "default": "/collections/all?filter.p.tag=men" },
    { "type": "header", "content": "Women's side" },
    { "type": "video",        "id": "women_video",   "label": "Women — Video (takes priority)" },
    { "type": "image_picker", "id": "women_image",   "label": "Women — Image (fallback)" },
    { "type": "text",         "id": "women_eyebrow", "label": "Eyebrow",     "default": "for her" },
    { "type": "text",         "id": "women_label",   "label": "Title",       "default": "women" },
    { "type": "text",         "id": "women_button",  "label": "Button text", "default": "shop women" },
    { "type": "url",          "id": "women_link",    "label": "Button link" }
  ],
  "presets": [{ "name": "Men / Women split" }]
}
{% endschema %}
