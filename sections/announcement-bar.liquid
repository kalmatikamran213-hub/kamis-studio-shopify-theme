{%- liquid
  assign bg = section.settings.bg_color | default: '#0A0A0A'
-%}
{%- if section.settings.message != blank -%}
  <div class="anno" style="background: {{ bg }};">
    <span>
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" style="color:inherit;text-decoration:none">{{ section.settings.message }}</a>
      {%- else -%}
        {{ section.settings.message }}
      {%- endif -%}
    </span>
    {%- if section.settings.dismissible -%}
      <button class="anno-close" aria-label="close">×</button>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text",     "id": "message",     "label": "Message", "default": "free shipping worldwide on orders over rs.25,000 →" },
    { "type": "url",      "id": "link",        "label": "Link" },
    { "type": "color",    "id": "bg_color",    "label": "Background", "default": "#3D1418" },
    { "type": "checkbox", "id": "dismissible", "label": "Dismissible", "default": true }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
