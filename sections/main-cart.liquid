{%- comment -%}
  Cart page — two-column layout: items left, sticky order summary right.
  Quantities post through Shopify's cart form; checkout button submits
  name="checkout" (Shopify's official checkout flow).
{%- endcomment -%}
{%- assign threshold = settings.free_shipping_threshold | default: 25000 | times: 100 -%}
<div class="page-wrap">
  <span class="page-eyebrow">bag · {{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %}</span>
  <h1 class="page-title">your bag</h1>

  {%- if cart.item_count == 0 -%}
    <div class="empty" style="padding: 48px 0;">
      <p>your bag is empty.</p>
      <p class="muted">drop:one of spring:summer '26 is now live.</p>
      <a class="btn-outline dark" style="text-decoration:none; margin-top: 18px" href="{{ routes.all_products_collection_url }}">shop drop:one</a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart-page-form" novalidate>
      <div class="co-layout" style="margin-top: 32px;">

        <div>
          {%- assign to_free = threshold | minus: cart.total_price -%}
          <div class="ship-progress" style="margin-bottom: 20px;">
            {%- if to_free > 0 -%}
              <span class="small">add {{ to_free | money }} for free shipping</span>
            {%- else -%}
              <span class="small">✓ free shipping unlocked</span>
            {%- endif -%}
            <div class="ship-bar">
              {%- assign pct = cart.total_price | times: 100.0 | divided_by: threshold -%}
              <div class="ship-fill" style="width: {% if pct > 100 %}100{% else %}{{ pct }}{% endif %}%"></div>
            </div>
          </div>

          <ul class="bag-list" style="border-top: 1px solid var(--rule); margin:0; padding:0;">
            {%- for item in cart.items -%}
              <li class="bag-item" style="padding: 18px 0; border-bottom: 1px solid var(--rule);">
                <a href="{{ item.url }}">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.product.title | escape }}">
                  {%- else -%}
                    {% render 'striped-placeholder', label: item.product.title, sub: 'image' %}
                  {%- endif -%}
                </a>
                <div class="bag-meta">
                  <a href="{{ item.url }}" style="color:inherit; text-decoration:none"><div class="bag-name">{{ item.product.title | downcase }}</div></a>
                  <div class="bag-variant">{% unless item.variant.title contains 'Default' %}{{ item.variant.title | downcase }}{% endunless %}</div>
                  <div class="bag-price">{{ item.final_line_price | money }}</div>
                  <div class="qty" style="margin-top: 8px">
                    <button type="button" data-qty="dec" aria-label="decrease">−</button>
                    <input name="updates[]" value="{{ item.quantity }}" type="number" min="0" aria-label="quantity">
                    <button type="button" data-qty="inc" aria-label="increase">+</button>
                  </div>
                </div>
                <button type="button" class="linklike small" data-remove>{{ 'cart.general.remove' | t }}</button>
              </li>
            {%- endfor -%}
          </ul>

          {%- if section.settings.show_note -%}
            <div style="margin-top: 24px;">
              <label class="form-label" for="cart-note">order note</label>
              <textarea class="form-input" id="cart-note" name="note" rows="3"
                        placeholder="anything we should know?">{{ cart.note }}</textarea>
            </div>
          {%- endif -%}
        </div>

        <aside class="co-summary">
          <h4>order summary</h4>
          <div class="co-line"><span>subtotal</span><span>{{ cart.total_price | money }}</span></div>
          <div class="co-line"><span>shipping</span><span>{% if to_free <= 0 %}free{% else %}at checkout{% endif %}</span></div>
          {%- if cart.total_discount > 0 -%}
            <div class="co-line"><span>discount</span><span>−{{ cart.total_discount | money }}</span></div>
          {%- endif -%}
          <div class="co-line total"><span>total</span><span>{{ cart.total_price | money }}</span></div>
          <button class="btn-fill" type="submit" name="checkout" style="width:100%">{{ 'cart.general.checkout' | t }}</button>
          <button class="btn-outline dark" type="submit" name="update" style="width:100%">update bag</button>
          <p class="muted small" style="margin:0">{{ 'cart.general.shipping_note' | t }}</p>
          <p class="muted small" style="margin:0">secure checkout · powered by shopify</p>
        </aside>

      </div>
    </form>

    <script>
      (function () {
        var form = document.getElementById('cart-page-form');
        if (!form) return;
        form.addEventListener('click', function (e) {
          var dec = e.target.closest('[data-qty="dec"]');
          var inc = e.target.closest('[data-qty="inc"]');
          var rm  = e.target.closest('[data-remove]');
          if (!dec && !inc && !rm) return;
          e.preventDefault(); e.stopPropagation();
          var item = e.target.closest('.bag-item');
          var input = item && item.querySelector('input[name="updates[]"]');
          if (!input) return;
          var q = parseInt(input.value, 10) || 0;
          if (dec) input.value = Math.max(0, q - 1);
          if (inc) input.value = q + 1;
          if (rm) input.value = 0;
          form.submit();
        }, true);
      })();
    </script>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "checkbox", "id": "show_note", "label": "Show order note field", "default": true }
  ]
}
{% endschema %}
