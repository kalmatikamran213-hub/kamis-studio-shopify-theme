{%- liquid
  assign source = section.settings.source
  assign related_products = empty
  if source == 'collection' and section.settings.related_collection != blank
    assign related_products = collections[section.settings.related_collection].products
  elsif product != blank
    assign related_products = product.collections.first.products
  endif
  if related_products == empty or related_products.size < 2
    assign related_products = collections['all'].products
  endif
-%}
<section class="stl">
  <h2 class="stl-h sfx-reveal" data-reveal>{{ section.settings.heading | default: 'you might also like' }}</h2>
  <div class="pg-grid pg-visible" style="border-bottom:1px solid var(--rule)">
    {%- assign shown = 0 -%}
    {%- for p in related_products -%}
      {%- if p.handle == product.handle -%}{%- continue -%}{%- endif -%}
      {%- if shown >= 4 -%}{%- break -%}{%- endif -%}
      <div class="pg-item" style="--i: {{ shown }}">
        {% render 'product-card', product: p %}
      </div>
      {%- assign shown = shown | plus: 1 -%}
    {%- endfor -%}
    {%- if shown == 0 -%}
      {%- for i in (1..4) -%}
        <div class="pg-item" style="--i: {{ forloop.index0 }}">
          {% render 'product-card', placeholder_label: 'related · placeholder' %}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "You might also like",
  "settings": [
    { "type": "text",  "id": "heading", "label": "Heading", "default": "you might also like" },
    { "type": "select", "id": "source", "label": "Related products source", "default": "auto",
      "options": [
        { "value": "auto",       "label": "Auto (same collection, falls back to catalog)" },
        { "value": "collection", "label": "Pick a collection" }
      ]
    },
    { "type": "collection", "id": "related_collection", "label": "Related collection" }
  ],
  "presets": [{ "name": "You might also like" }]
}
{% endschema %}
