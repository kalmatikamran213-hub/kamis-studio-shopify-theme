{%- comment -%}
  Bag drawer — free-shipping progress, qty steppers, subtotal, checkout.
  Server-rendered from `cart`; theme.js re-renders after Ajax cart changes.
{%- endcomment -%}
{%- assign threshold = settings.free_shipping_threshold | default: 25000 | times: 100 -%}
<div class="overlay overlay-hidden" data-overlay="bag" aria-hidden="true">
  <aside class="drawer bag" data-drawer-shell>
    <header class="drawer-h">
      <span>bag (<span data-bag-count>{{ cart.item_count }}</span>)</span>
      <button type="button" data-close aria-label="close">×</button>
    </header>
    <div class="drawer-body" data-cart-body
         data-threshold="{{ threshold }}"
         data-money-format="{{ shop.money_format | escape }}">
      {% render 'cart-contents', cart: cart, threshold: threshold %}
    </div>
  </aside>
</div>
