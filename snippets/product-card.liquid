{%- comment -%}
  Product card — matches the Kamis Studio design.
  Params: product (optional), placeholder_label, placeholder_bg, placeholder_fg
{%- endcomment -%}
{%- liquid
  assign first_image = product.featured_image
  assign hover_image = product.images[1] | default: first_image
  assign variant = product.selected_or_first_available_variant
-%}
<article class="card" data-card
  {%- if product %} onclick="if(!event.target.closest('button')&&!event.target.closest('a')){window.location='{{ product.url }}'}" style="cursor:pointer"{%- endif -%}>
  <div class="card-tag">
    {%- if product.metafields.kamis.tag != blank -%}{{ product.metafields.kamis.tag }}
    {%- elsif product.tags.first -%}{{ product.tags.first | downcase }}
    {%- else -%}new.in{%- endif -%}
  </div>

  <button class="card-bookmark" type="button" aria-label="save" data-wishlist
          {% if product %}data-slug="{{ product.handle }}"{% endif %}
          onclick="event.stopPropagation();this.classList.toggle('is-saved');var p=this.querySelector('path');if(p)p.setAttribute('fill',this.classList.contains('is-saved')?'#0A0A0A':'none')">
    <svg width="14" height="16" viewBox="0 0 14 16" fill="none" stroke="#0A0A0A" stroke-width="1.2"><path d="M1 1 H13 V15 L7 11 L1 15 Z"/></svg>
  </button>

  {%- if product -%}
    <a href="{{ product.url }}" class="card-img-wrap" aria-label="{{ product.title | escape }}" onclick="event.stopPropagation()">
      {%- if first_image -%}
        <img src="{{ first_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="card-img" loading="lazy" width="800" height="1000">
      {%- else -%}
        {% render 'striped-placeholder', label: product.title, sub: 'flat', bg: '#EFEDE8', fg: '#D9D5CC', class: 'card-img' %}
      {%- endif -%}
      {%- if hover_image and hover_image != first_image -%}
        <img src="{{ hover_image | image_url: width: 800 }}" alt="" aria-hidden="true" class="card-img card-img-hover" loading="lazy" width="800" height="1000">
      {%- endif -%}
      <form action="{{ routes.cart_add_url }}" method="post" style="margin:0" data-quick-add>
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="card-quick" type="submit" onclick="event.stopPropagation()">+ quick add</button>
      </form>
    </a>
  {%- else -%}
    <div class="card-img-wrap">
      {% render 'striped-placeholder', label: placeholder_label | default: 'product · placeholder', sub: 'add product in shopify', bg: placeholder_bg, fg: placeholder_fg, class: 'card-img' %}
    </div>
  {%- endif -%}

  <div class="card-meta">
    <div class="card-name-row">
      <span class="card-name">{{ product.title | default: 'product name' | downcase }}</span>
      <span class="card-variant">{{ product.metafields.kamis.variant | default: variant.title | default: '' | downcase | remove: 'default title' }}</span>
    </div>
    {%- if product -%}
      <div class="card-price">{{ variant.price | money }}</div>
    {%- else -%}
      <div class="card-price muted">add in shopify</div>
    {%- endif -%}
  </div>

  {%- if product -%}
    {%- for opt in product.options_with_values -%}
      {%- assign on = opt.name | downcase -%}
      {%- if on contains 'color' or on contains 'colour' -%}
        <div class="card-swatches">
          {%- for v in opt.values limit: 5 -%}
            <span class="sw" style="background:{{ v | downcase | handle }}"></span>
          {%- endfor -%}
        </div>
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
</article>
